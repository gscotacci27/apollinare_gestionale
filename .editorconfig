# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.R]
indent_size = 2

[*.{md,markdown,Rmd}]
indent_size = 1
trim_trailing_whitespace = false

[*.{yaml,yml,json,talismanrc}]
indent_size = 2

[*.bat]
end_of_line = crlf
indent_style = tab

[Makefile]
indent_style = tab

[docs/**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset
